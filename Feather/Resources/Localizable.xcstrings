    "Show your support by donating! If you're unable to donate, spreading the word works too!": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukažte svojí podporu díky podpoření! Pokud nemůžete podpořit, alespoň se o aplikaci podělte s ostatními!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeige deine Unterstützung durch eine Spende! Wenn du nicht spenden kannst, hilft es auch, dieses Projekt zu teilen!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show your support by donating! If you're unable to donate, spreading the word works too!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dukung kami dengan berdonasi! Jika Anda tidak bisa berdonasi, menyebarkan informasi juga sangat membantu!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra il tuo supporto donando! Se non puoi donare, può funzionare anche condividerlo con il mondo!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Okaż wsparcie poprzez darowiznę! Jeśli nie możesz wesprzeć finansowo, podziel się informacją z innymi!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağış yaparak desteğinizi gösterin! Eğer bağış yapamıyorsanız Feather’ı dilden dile yaymak da işe yarar!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thể hiện sự ủng hộ của bạn bằng cách quyên góp! Nếu bạn không thể quyên góp, việc chia sẻ cho người khác biết cũng có tác dụng!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "捐赠来支持我们！如果你不能捐赠，请帮我们多多宣传！"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أظهر دعمك من خلال التبرع! إذا لم تتمكن من التبرع، فإن نشر الكلمة يعمل أيضاً!"
          }
        }
      }
    },
    "Sign": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
