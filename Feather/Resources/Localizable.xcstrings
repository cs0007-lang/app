    "You cannot update ‘%@‘ with itself, please use an alternative tool to update it.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst ‘%@‘ nicht mit sich selbst aktualisieren. Bitte verwende dafür ein alternatives Tool."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You cannot update ‘%@‘ with itself, please use an alternative tool to update it."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu tidak bisa melakukan update pada ‘%@’ menggunakan dirinya sendiri. Silakan gunakan tool alternatif untuk memperbaruinya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non puoi aggiornare ‘%@‘ con se stesso, usa un altro tool per fare l’aggiornamento."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można zaktualizować „%@” przy jego użyciu. Użyj innego narzędzia do aktualizacji."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@’ı kendisi üzerinden güncelleyemezsiniz. Lütfen güncelleme için alternatif bir araç kullanın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn không thể cập nhật ‘%@‘ bằng chính nó, vui lòng sử dụng công cụ thay thế để cập nhật."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不能用‘%@’更新自己，请使用其他工具更新。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكنك تحديث '%@' بنفسه، يرجى استخدام أداة بديلة لتحديثه."
          }
        }
      }
    },
    "Your pairing file is invalid and is incompatible with your device, please import a valid pairing file.": {
