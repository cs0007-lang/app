      }
    },
    "Get access to our secret Discord by donating, where we talk about future updates, betas, and potential ways to make your experience better.": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Získejte po podpoření přístup k našemu skrytému Discordu, kde se mluví o dalších aktualizacích, beta verzích a vylepšeních."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalte durch eine Spende Zugang zu unserem geheimen Discord, in dem wir über zukünftige Updates, Betas und mögliche Verbesserungen deines Nutzererlebnisses sprechen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get access to our secret Discord by donating, where we talk about future updates, betas, and potential ways to make your experience better."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dapatkan akses ke Discord rahasia kami dengan berdonasi, di mana kami membahas pembaruan mendatang, versi beta, dan cara-cara potensial untuk meningkatkan pengalaman Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ottieni l'accesso al nostro server Discord segreto donando, dove parliamo di nuove funzionalità, beta e nuovi modi per rendere la tua esperienza migliore."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uzyskaj dostęp do naszego prywatnego Discorda poprzez wsparcie, gdzie rozmawiamy o przyszłych aktualizacjach, wersjach beta i możliwościach poprawy doświadczeń."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağış yaparak gelecekteki güncellemeler, beta sürümleri ve deneyiminizi daha iyi hale getirmenin yolları hakkında konuştuğumuz gizli Discord sunucumuza erişin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhận quyền truy cập vào Discord riêng của chúng tôi bằng cách quyên góp, nơi chúng tôi thảo luận về các bản cập nhật tương lai, phiên bản beta và các cách tiềm năng để cải thiện trải nghiệm của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过捐赠加入我们的秘密Discord来获取有关未来更新、测试版和提升使用体验的资讯。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على الوصول إلى Discord السري الخاص بنا من خلال التبرع، حيث نتحدث عن التحديثات المستقبلية والإصدارات التجريبية والطرق المحتملة لتحسين تجربتك."
          }
        }
      }
    },
