    "These changes require a restart of the app": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tyto změny vyžadují restart aplikace"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Änderungen benötigen einen Neustart der App"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These changes require a restart of the app"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengaktifkan tampilan lembar akan menampilkan lembar berbagi setelah mengekspor ke berkas Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi cambiamenti richiedono un riavvio dell'app"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Te zmiany wymagają ponownego uruchomienia aplikacji"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu değişiklikler uygulamanın yeniden başlatılmasını gerektirir"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Những thay đổi này yêu cầu khởi động lại ứng dụng"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些改动需要重启应用。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذه التغييرات تتطلب إعادة تشغيل التطبيق"
          }
        }
      }
    },
    "This action cannot be undone. Would you like to proceed?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Aktion kann nicht rückgängig gemacht werden. Möchtest du fortfahren?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This action cannot be undone. Would you like to proceed?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa operazione non può essere annullata. Vuoi procedere?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tej czynności nie można cofnąć. Czy chcesz kontynuować?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu eylem geri alınamaz. Devam etmek istiyor musunuz?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không thể hoàn tác hành động này. Bạn có muốn tiếp tục không?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "操作无法撤销，确定继续？"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن التراجع عن هذا الإجراء. هل تريد المتابعة؟"
          }
        }
      }
    },
    "This allows you to set rules for automatically replacing the Bundle ID/Display Name when signing an app.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This allows you to set rules for automatically replacing the Bundle ID/Display Name when signing an app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Umożliwia ustawienie reguł automatycznej zamiany identyfikatora pakietu/wyświetlanej nazwy podczas podpisywania aplikacji."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, uygulamaları imzalarken otomatik olarak paket kimliği ya da görünen adı değiştirmenize yardımcı olan kurallar koymanızı sağlar."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Điều này cho phép bạn thiết lập các quy tắc để tự động thay thế Bundle ID/Tên hiển thị khi ký ứng dụng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些选项设置在为应用签名时自动替换包ID/显示名称的规则。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسمح لك هذا بتعيين قواعد لاستبدال معرف الحزمة/اسم العرض تلقائياً عند توقيع تطبيق."
          }
        }
      }
    },
    "This enables liquid glass for this app, this requires a restart of the app to take effect.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies aktiviert Liquid Glass für diese App. Damit die Änderung wirksam wird, muss die App neu gestartet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This enables liquid glass for this app, this requires a restart of the app to take effect."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo abilita il liquid glass per l'app, questo richiede un riavvio dell'app per dare effetto."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącza liquid glass dla tej aplikacji. Wymaga ponownego uruchomienia, aby zmiany zostały zastosowane."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, Liquid Glass arayüzünü etkinleştirir. Değişikliklerin etkili olabilmesi için uygulamanın yeniden başlatılması gereklidir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Điều này cho phép sử dụng liquid glass cho ứng dụng này, điều này yêu cầu khởi động lại ứng dụng để có hiệu lực."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为此应用启用Liquid Glass。需要重启应用。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا يفعل liquid glass لهذا التطبيق، يتطلب إعادة تشغيل التطبيق لتطبيق التغيير."
          }
        }
      }
    },
    "This option force converts apps to try to use the new liquid glass redesign iOS 26 introduced, this may not work for all applications due to differing frameworks.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Option erzwingt die Umstellung von Apps auf das neue Liquid-Glass-Redesign, das mit iOS 26 eingeführt wurde. Aufgrund unterschiedlicher Frameworks funktioniert dies möglicherweise nicht bei allen Anwendungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This option force converts apps to try to use the new liquid glass redesign iOS 26 introduced, this may not work for all applications due to differing frameworks."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa opzione forza la conversione delle app per provare a usare il nuovo redesign liquid glass introdotto con iOS 26, però non funziona su tutte le app per via dei framework diversi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta opcja wymusza konwersję aplikacji na nowy wygląd liquid glass wprowadzony w iOS 26. Może nie działać ze wszystkimi aplikacjami z powodu różnych frameworków."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu seçenek, uygulamaları iOS 26'da tanıtılan yeni Liquid Glass arayüzünü kullanmaya zorlar. Farklı Framework’ler nedeniyle bu, tüm uygulamalarda işe yaramayabilir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tùy chọn này buộc phải chuyển đổi ứng dụng để thử sử dụng giao diện Liquid Glass mới được giới thiệu trong iOS 26. Tùy chọn này có thể không hoạt động với tất cả các ứng dụng do có nhiều khuôn khổ khác nhau."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此选项强制为应用启用iOS 26的Liquid Glass。由于使用的框架不同，此选项不一定有效果。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الخيار يجبر تحويل التطبيقات لمحاولة استخدام تصميم liquid glass الجديد الذي قدمه iOS 26، قد لا يعمل هذا مع جميع التطبيقات بسبب اختلاف الأطر."
          }
        }
      }
    },
    "This will delete your imported application after signing, to save on using unneeded space.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies wird deine importierte Datei nach der Signierung löschen, um Speicherplatz zu sparen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will delete your imported application after signing, to save on using unneeded space."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina l'applicazione importata dopo la firma, per salvare spazio usato inutilmente."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to usunięcie zaimportowanej aplikacji po jej podpisaniu, co pozwoli zwolnić miejsce."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, imzaladıktan sonra içe aktarılan uygulamayı silerek gereksiz alanı geri kazanmanıza yardımcı olur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa ứng dụng đã nhập của bạn sau khi ký, để tiết kiệm dung lượng không cần thiết."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
