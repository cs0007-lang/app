    "Removing the provisioning file will exclude the mobileprovision file from being embedded inside of the application when signing, to help prevent any detection.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removing the provisioning file will exclude the mobileprovision file from being embedded inside of the application when signing, to help prevent any detection."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovere il file di provisioning escluderà il file .mobileprovision dall’essere incorporato nell’app durante la firma, aiutando così a evitare qualsiasi rilevamento."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunięcie pliku provisioning spowoduje, że plik mobileprovision nie będzie osadzony w aplikacji podczas podpisywania, co zapobiegnie jakiemukolwiek wykryciu."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazırlık profilinin kaldırılması imzalama sırasında “mobileprovision” dosyasının uygulamaya dahil edilmemesini sağlayarak herhangi bir tespitin önlenmesine yardımcı olur. "
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa tệp mobileprovision được nhúng bên trong ứng dụng khi ký, giúp ngăn chặn mọi phát hiện."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除描述文件后，签名时就不会将其嵌入到App中，从而防止被检测到。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إزالة ملف التوفير سيستبعد ملف mobileprovision من أن يتم تضمينه داخل التطبيق عند التوقيع، للمساعدة في منع أي اكتشاف."
          }
        }
      }
    },
