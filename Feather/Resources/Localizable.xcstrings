    "Enter the password associated with the private key. Leave it blank if theres no password required.": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadejte heslo spojené s privátním klíčem. Když žádné není potřeba, nezadávejte ho."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib das mit dem privaten Schlüssel verknüpfte Passwort ein. Lass das Feld leer, wenn kein Passwort erforderlich ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the password associated with the private key. Leave it blank if theres no password required."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduzca la contraseña asociada a la llave privada, déjalo en blanco si una contraseña no es necesaria."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez le mot de passe associé à la clé privée, laissez vide si aucun mot de passe n'est requis."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan kata sandi yang terkait dengan kunci privat. Biarkan kosong jika tidak diperlukan kata sandi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci la password associata alla chiave privata. Lascia vuoto se la password non è richiesta."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wprowadź hasło powiązane z kluczem prywatnym. Pozostaw puste, jeśli nie jest wymagane hasło."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите пароль, связанный с закрытым ключом, оставьте поле пустым, если пароль не требуется."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Özel anahtarla ilişkilendirilmiş parolayı girin. Parola gerekmiyorsa boş bırakın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập mật khẩu của chứng chỉ. Để trống nếu không yêu cầu mật khẩu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入你的私钥的密码。没有密码则留空。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل كلمة المرور المرتبطة بالشهادة الخاصه بك. اتركه فارغاً إذا لم تكن هناك كلمة مرور."
          }
        }
      }
    },
